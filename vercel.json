{
    "version": 2,
    "builds": [
        {
            "src": "rag-api/src/server.js",
            "use": "@vercel/node"
        },
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "."
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/chat",
            "destination": "/rag-api/src/server.js"
        },
        {
            "source": "/api/health",
            "destination": "/rag-api/src/server.js"
        }
    ]
}